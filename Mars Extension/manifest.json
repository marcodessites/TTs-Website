{
  "manifest_version": 3,
  "name": "Mars Extension",
  "version": "1.0",
  "description": "Toggle Auto Correct on and off for text fields.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
